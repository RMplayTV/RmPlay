<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.video.rmtv" 
       name="RM-TV" 
       version="1.0.0" 
       provider-name="Raul Matos">
    
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>video</provides>
    </extension>
    
    <extension point="xbmc.addon.metadata">
        <summary>RM-TV Streaming Completo</summary>
        <description>
Addon completo para streaming:
📺 TV AO VIVO - Assista canais com M3U
🎬 FILMES - Sua biblioteca de filmes
📺 SÉRIES - Suas séries favoritas
🧸 DESENHOS - Conteúdo animado
🔍 PESQUISA - Busque por conteúdo

Desenvolvido por Raul Matos
        </description>
        <platform>all</platform>
        <language>pt_BR</language>
        <license>GPL v2.0</license>
    </extension>
    
</addon>
